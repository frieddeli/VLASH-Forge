# Copy this file to .env and fill in your values.
# .env is loaded automatically by docker-compose.
# For scripts/train.sh, export these in your shell or source this file.
#
# NEVER commit .env to git — it contains secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# HuggingFace token with read+write access.
# Get one at: huggingface.co/settings/tokens
# Required to download gated models (pi0/pi0.5) and push trained checkpoints.
HF_TOKEN=hf_xxx

# HuggingFace dataset repo ID uploaded via huggingface-cli.
# e.g. your-org/your-dataset
DATASET_REPO_ID=your-org/your-dataset

# Path to persistent storage on the host — bind-mounted to /scratch in container.
#   HPC (NSCC/SLURM):      SCRATCH=/scratch/users/ntu/your-id
#   AWS EBS:               SCRATCH=/mnt/ebs
#   GCP Persistent Disk:   SCRATCH=/mnt/pd
#   GCS FUSE (mount first) SCRATCH=/mnt/gcs
#   Local workstation:     SCRATCH=$HOME/vlash-scratch
SCRATCH=/your/persistent/storage

# ── Optional ──────────────────────────────────────────────────────────────────

# Number of GPUs to use (default: 4 for compose, 1 for train.sh)
NUM_GPUS=4

# Training backend:
#   deepspeed  — ZeRO-2, recommended for LoRA fine-tuning (default)
#   fsdp       — full parameter sharding, required for full fine-tuning (lora.enable: false)
TRAIN_BACKEND=deepspeed

# W&B API key — only needed when wandb.enable: true in your training config.
# Get one at: wandb.ai/settings
WANDB_API_KEY=
